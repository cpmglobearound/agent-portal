# SeaTable API Tokens
SEATABLE_CUSTOMERS_TOKEN=your_customers_token_here
SEATABLE_AGENTS_TOKEN=your_agents_token_here
SEATABLE_BACKUPS_TOKEN=your_backups_token_here
SEATABLE_DEPLOYMENTS_TOKEN=your_deployments_token_here

# SeaTable Base UUIDs
SEATABLE_UUID_CUSTOMERS=your_customers_uuid_here
SEATABLE_UUID_AGENTS=your_agents_uuid_here
SEATABLE_UUID_BACKUPS=your_backups_uuid_here
SEATABLE_UUID_DEPLOYMENTS=your_deployments_uuid_here

# N8N Webhook URL
N8N_DEPLOY_URL=https://n8n-hetzner.deseoai.com/webhook/deploy-agent

# NextAuth Configuration
NEXTAUTH_SECRET=your_secret_key_minimum_32_characters_long
NEXTAUTH_URL=https://portal.deseoai.com

# Port Configuration (optional)
PORT=3001

# Notion API Token
NOTION_API_TOKEN=your_notion_integration_token_here
